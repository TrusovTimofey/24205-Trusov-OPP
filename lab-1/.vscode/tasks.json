{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build And Run",
            "type": "shell",
            "command": "mpicxx ${workspaceFolder}/main.cpp && mpirun -np 1 ${workspaceFolder}/a.out",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "type": "cppbuild",
            "label": "C/C++: mpicc сборка активного файла",
            "command": "/usr/lib64/openmpi/bin/mpicc",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Задача создана отладчиком."
        }
    ]
}